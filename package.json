{
	"name": "mega-front-starter",
	"version": "5.0.0",
	"description": "Gulp Bootstrap5 scss Pug",
	"main": "block.js",
	"type": "module",
	"scripts": {
		"dev": "gulp",
		"gulp": "gulp",
		"build": "NODE_ENV=production gulp build",
		"libs": "gulp libs",
		"lint": "npx eslint \"source/js/**/*.js\"",
		"lint:fix": "npm run lint -- --fix",
		"prettier": "npx prettier \"source/js/**/*.js\" \"gulpfile.js\" \"*.json\" --check",
		"prettier:fix": "npm run prettier -- --write",
		"format": "npm run prettier:fix && npm run lint:fix"
	},
	"lint-staged": {
		"*.{js,json,css,md,html}": [
			"prettier --single-quote --write",
			"git add"
		]
	},
	"husky": {
		"hooks": {
			"pre-commit": "lint-staged"
		}
	},
	"author": "Khalunin Pavel",
	"license": "ISC",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"autoprefixer": "^10.4.20",
		"bootstrap": "5.3.3",
		"browser-sync": "^3.0.2",
		"browserslist": "^4.28.1",
		"caniuse-lite": "^1.0.30001777",
		"colors": "^1.4.0",
		"cssnano": "^7.0.6",
		"del": "^8.0.0",
		"eslint": "^9.17.0",
		"globals": "^17.4.0",
		"gulp": "^5.0.0",
		"gulp-cheerio": "^1.0.0",
		"gulp-data": "^1.3.1",
		"gulp-notify": "^5.0.0",
		"gulp-npm-dist": "^1.0.4",
		"gulp-plumber": "^1.2.1",
		"gulp-postcss": "^10.0.0",
		"gulp-pug": "^5.0.0",
		"gulp-rename": "^2.0.0",
		"gulp-replace": "^1.1.4",
		"gulp-sass": "^6.0.0",
		"gulp-sass-glob": "^1.1.0",
		"gulp-svg-sprite": "^2.0.3",
		"gulp-svgmin": "^4.1.0",
		"gulp-tabify": "0.0.2",
		"husky": "^9.1.7",
		"postcss": "^8.5.3",
		"postcss-nested": "^7.0.2",
		"postcss-sort-media-queries": "^5.2.0",
		"prettier": "^3.5.1",
		"sass": "1.77.6"
	},
	"dependencies": {
		"@fancyapps/ui": "^5.0.36",
		"inputmask": "^5.0.9",
		"jquery": "^3.7.1",
		"select2": "^4.1.0-rc.0",
		"swiper": "^11.2.4"
	}
}
